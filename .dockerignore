# Keep the build context small and never bake host secrets/data into the image.
node_modules
build
.svelte-kit
.git
.gitignore
# Host secrets and database must NOT enter the image — each install makes its own.
.env
.env.*
!.env.docker.example
*.db
*.db-journal
*.db-wal
*.db-shm
backups
# Not needed to run the app:
worker
docs
**/*.test.ts
