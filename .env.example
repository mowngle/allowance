# Copy to .env. Or leave .env nonexistent and the app will create one on first boot.
#
# Values starting blank are auto-generated by src/lib/server/bootstrap.ts on first
# server boot. You can pre-set them yourself if you want specific values; otherwise
# the app handles it.

DATABASE_URL=./dev.db
PORT=3000

# Auto-generated on first boot if blank.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Auto-generated on first boot if blank.
SESSION_SECRET=
