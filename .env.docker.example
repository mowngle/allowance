# Copy to .env (in this directory), fill in the values, then `docker compose up -d`.
# Generate the secret lines with:  docker compose run --rm app node scripts/gen-secrets.js
# (or, if you have Node installed locally:  npm run gen-secrets)

# The address OTHER devices in your home use to reach this app — your host machine's
# LAN IP and port. It MUST match how you actually open the app in a browser, or logins
# are rejected (SvelteKit cross-site form protection). Reserve a static IP for this
# machine in your router so it doesn't change.
ORIGIN=http://192.168.1.50:3000

# Where the SQLite database lives INSIDE the container (on the persistent volume).
# Leave this exactly as-is.
DATABASE_URL=/data/app.db

# Port the app listens on inside the container. Leave as 3000. To expose a different
# EXTERNAL port, set HOST_PORT below instead (docker-compose maps HOST_PORT -> 3000).
PORT=3000
# HOST_PORT=3000

# --- Secrets (unique per household). Paste the output of gen-secrets here. ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@localhost
SESSION_SECRET=
